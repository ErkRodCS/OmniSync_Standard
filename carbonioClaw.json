{
  "name": "omnisync-hybrid",
  "version": "1.0.0",
  "description": "Indenpendent Universal Sync Engine. High-performance, low-token delta protocol for agents and IoT.",
  "author": "@erk",
  "license": "MIT",
  "standalone": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/ErkRodCS/OmniSync.git"
  },
  "source_url": "https://github.com/ErkRodCS/OmniSync.git",
  "engines": {
    "standard": "omnisync_engine.py"
  },
  "tools": [
    {
      "name": "sync_standard",
      "description": "Standard SHA-256 secure synchronization (FREE)",
      "inputSchema": {
        "type": "object",
        "properties": {
          "feed_id": {"type": "string"},
          "new_content": {"type": "string"},
          "old_content": {"type": "string"},
          "last_hash": {"type": "string"}
        },
        "required": ["feed_id", "new_content", "old_content"]
      }
    }
  ],
  "monetization": {
    "type": "L402",
    "suggested_price_sats": 50,
    "tools": {
      "sync_standard": 0
    }
  }
}
